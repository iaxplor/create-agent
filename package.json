{
  "name": "@iaxplor/create-agent",
  "version": "0.9.1",
  "description": "CLI IAxplor — cria projetos de agente de IA e instala módulos adicionais (Evolution API, etc.) a partir do template core.",
  "keywords": [
    "iaxplor",
    "create-agent",
    "agent",
    "whatsapp",
    "cli",
    "template",
    "agno"
  ],
  "author": "IAxplor",
  "license": "MIT",
  "type": "module",
  "bin": {
    "create-agent": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iaxplor/create-agent.git"
  },
  "bugs": {
    "url": "https://github.com/iaxplor/create-agent/issues"
  },
  "homepage": "https://github.com/iaxplor/create-agent#readme",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "diff": "^9.0.0",
    "execa": "^9.5.0",
    "fs-extra": "^11.2.0",
    "giget": "^3.2.0",
    "ora": "^8.1.0",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/diff": "^8.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.5.0",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
